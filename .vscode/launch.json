{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Auth Service",
            "cargo": {
                "args": [
                    "build",
                    "--package",
                    "auth-service",
                    "--bin",
                    "auth-service"
                ],
                "filter": {
                    "name": "auth-service",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/crates/auth-service",
            "sourceLanguages": [
                "rust"
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Social Service",
            "cargo": {
                "args": [
                    "build",
                    "--package",
                    "social-service",
                    "--bin",
                    "social-service"
                ],
                "filter": {
                    "name": "social-service",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/crates/social-service",
            "sourceLanguages": [
                "rust"
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Matchmaking Service",
            "cargo": {
                "args": [
                    "build",
                    "--package",
                    "matchmaking-service",
                    "--bin",
                    "matchmaking-service"
                ],
                "filter": {
                    "name": "matchmaking-service",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/crates/matchmaking-service",
            "sourceLanguages": [
                "rust"
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Realtime Service",
            "cargo": {
                "args": [
                    "build",
                    "--package",
                    "realtime-service",
                    "--bin",
                    "realtime-service"
                ],
                "filter": {
                    "name": "realtime-service",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/crates/realtime-service",
            "sourceLanguages": [
                "rust"
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Game Service",
            "cargo": {
                "args": [
                    "build",
                    "--package",
                    "game-service",
                    "--bin",
                    "game-service"
                ],
                "filter": {
                    "name": "game-service",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/crates/game-service",
            "sourceLanguages": [
                "rust"
            ]
        },
        {
            "type": "node-terminal",
            "request": "launch",
            "name": "Demo Frontend",
            "command": "npm --prefix demo run dev",
            "cwd": "${workspaceFolder}"
        },
    ],
    "compounds": [
        {
            "name": "All Services",
            "configurations": [
                "Auth Service",
                "Social Service",
                "Matchmaking Service",
                "Realtime Service",
                "Game Service"
            ],
            "stopAll": true
        },
        {
            "name": "Demo Flow",
            "configurations": [
                "Auth Service",
                "Realtime Service",
                "Game Service",
                "Demo Frontend"
            ],
            "stopAll": true
        }
    ]
}